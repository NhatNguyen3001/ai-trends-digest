# Copy this file to ".env" and fill in your real values.
# ".env" is git-ignored and must NEVER be committed.

# --- Anthropic (Claude) ---
# Get a key at https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=

# Default model the app uses. Override here if you want a different one.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- GitHub (optional) ---
# Optional: only raises the GitHub Search API rate limit. Leave blank to use the
# keyless limit (~10 searches/min), which is plenty for the daily digest.
GITHUB_TOKEN=

# --- Voyage AI (embeddings) ---
# Free tier: https://www.voyageai.com/. Used for semantic de-duplication. Without
# it, the digest still runs but skips the semantic dedup step.
VOYAGE_API_KEY=

# --- Tavily (deep-dive web search, Phase 5) ---
# Free tier (~1k searches/mo): https://tavily.com/. Used only by the on-demand
# deep-dive engine. Without it, a deep-dive soft-fails to "" and the digest is
# unaffected.
TAVILY_API_KEY=
